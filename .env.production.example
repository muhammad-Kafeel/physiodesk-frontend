# ══════════════════════════════════════════════════════════════════════════════
#  PhysioDesk Frontend — PRODUCTION .env template
#  Set these on your hosting platform (Vercel, Netlify, cPanel, etc.)
# ══════════════════════════════════════════════════════════════════════════════

# Your Laravel backend URL (no trailing slash)
VITE_API_URL=https://api.yourdomain.com/api  # ← FILL IN

# Bank transfer details shown to patients on the payment page
# Update these without a code deployment by changing env vars only
VITE_BANK_NAME=HBL                           # ← FILL IN your bank name
VITE_BANK_ACCOUNT=                           # ← FILL IN your account number
VITE_BANK_TITLE=PhysioDesk Pvt Ltd           # ← FILL IN your registered company name
